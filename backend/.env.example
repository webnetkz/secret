PORT=3100
HOST=0.0.0.0

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=secret_chat
DB_CONNECTION_LIMIT=10
DB_AUTO_CREATE=true

# Comma-separated user IDs with elevated rights:
# - see all chats
# - join any chat without password
# - delete any message
SUPER_USER_IDS=

# One-time super admin activation key for web query param ?admin=<key>
# Note: backward-compatible alias KEY_AMIND is also supported by backend.
KEY_ADMIN=KEY_ADMIN
